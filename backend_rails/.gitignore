# Rails credentials — never commit these
/config/master.key
/config/credentials.yml.enc
/config/credentials/

# Logs and temp files
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# SQLite databases
/db/*.sqlite3
/db/*.sqlite3-journal
/db/*.sqlite3-wal
/db/*.sqlite3-shm

# Environment files
.env
.env.*

# Bundled gems — use bundle install locally
/vendor/bundle/
/.bundle/

# Storage (AI-generated game summaries, warehouse CSVs)
/storage/
